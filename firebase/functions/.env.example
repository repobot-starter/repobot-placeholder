# Environment variables for firebase/functions.
# The manifest of record is /env.manifest.json at the repo root; `npm run bootstrap:env`
# generates .env.local from it. This file documents the variables and is the only
# .env.* file that is committed.

# Postgres connection string for this environment's database.
# Local core db: postgres://postgres:postgres@127.0.0.1:5432/postgres
# Local test db: postgres://postgres:postgres@127.0.0.1:5433/postgres
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres

# "local" (emulator-only dev principal tokens) or "builtin" (the kernel's own
# auth service). Deployed boot refuses "local" and crashes with a clear message.
AUTH_MODE=local

# HS256 hex secret for locally issued dev tokens (local/test only).
# Generated per checkout by `npm run bootstrap:env`; never used when deployed.
LOCAL_AUTH_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# HS256 hex secret that signs and verifies built-in auth JWTs (dev/prod only).
# Generated per environment by the platform when the AUTH capability is
# declared in repobot.deploy.json; never set this locally.
AUTH_JWT_SECRET=

# Public URL of the auth__request__api function (dev/prod only). Used for
# OAuth callbacks and the magic-link fallback URLs in auth emails.
AUTH_PUBLIC_URL=

# The environment's live site URL (dev/prod only). {{ .SiteURL }} in auth
# emails and the OAuth redirect allowlist; tracks the custom domain.
APP_BASE_URL=

# SMTP account for auth emails (dev/prod only; injected by the platform).
# Empty host = degraded mode: signups auto-confirm, OTP/recovery unavailable.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_EMAIL=
SMTP_SENDER_NAME=

# Auth email template overrides (dev/prod only; injected by the platform from
# repobot.emails.json + dashboard overrides) as JSON or base64-encoded JSON.
# Empty = kernel defaults.
AUTH_EMAIL_TEMPLATES=

# Google OAuth client for the "google" sign-in method (dev/prod only;
# injected from the account's Google Sign-In integration).
GOOGLE_SIGNIN_CLIENT_ID=
GOOGLE_SIGNIN_CLIENT_SECRET=

# "local" (in-app simulated test checkout; emulator/tests only) or "stripe".
# Deployed boot refuses "local" and crashes with a clear message.
PAYMENTS_MODE=local

# Stripe API secret key (dev/prod only). Injected by the platform from the
# account's connected Stripe integration when the PAYMENTS capability is
# declared in repobot.deploy.json; never set this locally.
STRIPE_SECRET_KEY=

# "local" (simulated assistant; emulator/tests only) or "openai".
# Deployed boot refuses "local" and crashes with a clear message.
AI_MODE=local

# OpenAI API secret key (dev/prod only). Injected by the platform when the AI
# capability is declared in repobot.deploy.json. To try the real model in a
# local sandbox, set AI_MODE=openai and paste a key here.
OPENAI_API_KEY=
