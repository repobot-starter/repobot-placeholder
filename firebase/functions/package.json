{
    "name": "functions",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "engines": {
        "node": "20"
    },
    "main": "lib/src/index.js",
    "scripts": {
        "prebuild": "bash prebuild.sh",
        "build": "tsc -p tsconfig.json",
        "lint": "eslint .",
        "test": "mocha",
        "migrate": "tsx scripts/migrate.ts",
        "migrate:test": "tsx scripts/migrate.ts --test",
        "drift-check": "bash scripts/drift-check.sh",
        "configure-pubsub": "tsx scripts/configure-pubsub.ts",
        "serve": "npm run build && npx firebase-tools emulators:start --only functions --project demo-repobot-base"
    },
    "dependencies": {
        "@apollo/server": "4.13.0",
        "@bufbuild/protobuf": "2.12.1",
        "@google-cloud/pubsub": "4.11.0",
        "cors": "2.8.6",
        "dataloader": "2.2.3",
        "dotenv": "16.6.1",
        "drizzle-orm": "0.44.7",
        "drizzle-zod": "0.7.1",
        "express": "4.22.2",
        "firebase-admin": "12.7.0",
        "firebase-functions": "6.6.0",
        "graphql": "16.14.2",
        "jose": "5.10.0",
        "nodemailer": "7.0.13",
        "pg": "8.22.0",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@bufbuild/buf": "1.71.0",
        "@bufbuild/protoc-gen-es": "2.12.1",
        "@graphql-codegen/cli": "5.0.7",
        "@graphql-codegen/typescript": "4.1.6",
        "@graphql-codegen/typescript-resolvers": "4.5.2",
        "@types/chai": "4.3.20",
        "@types/chai-as-promised": "7.1.8",
        "@types/cors": "2.8.19",
        "@types/express": "4.17.25",
        "@types/mocha": "10.0.10",
        "@types/node": "20.19.43",
        "@types/nodemailer": "7.0.4",
        "@types/pg": "8.20.0",
        "@types/sinon": "17.0.4",
        "chai": "4.5.0",
        "chai-as-promised": "7.1.2",
        "drizzle-kit": "0.31.10",
        "eslint": "9.39.5",
        "eslint-config-prettier": "9.1.2",
        "eslint-plugin-drizzle": "0.2.3",
        "mocha": "10.8.2",
        "pg-transactional-tests": "1.2.1",
        "prettier": "3.9.5",
        "sinon": "19.0.5",
        "tsx": "4.23.1",
        "typescript": "5.6.3",
        "typescript-eslint": "8.64.0"
    }
}
