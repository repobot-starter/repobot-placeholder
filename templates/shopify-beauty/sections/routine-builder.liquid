<section class="routine-builder">
  {% if section.settings.eyebrow != blank %}
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <h2 class="routine-builder__title">{{ section.settings.title }}</h2>
  {% if section.settings.intro != blank %}
    <p class="routine-builder__intro">{{ section.settings.intro }}</p>
  {% endif %}
  <div class="routine-builder__columns">
    <div class="routine-builder__column">
      <span class="routine-builder__column-label">{{ 'sections.routine_builder.am' | t }}</span>
      <ol class="routine-builder__steps">
        {% for block in section.blocks %}
          {% if block.settings.time == 'am' %}
            <li class="routine-builder__step" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.why }}</p>
            </li>
          {% endif %}
        {% endfor %}
      </ol>
    </div>
    <div class="routine-builder__column">
      <span class="routine-builder__column-label">{{ 'sections.routine_builder.pm' | t }}</span>
      <ol class="routine-builder__steps">
        {% for block in section.blocks %}
          {% if block.settings.time == 'pm' %}
            <li class="routine-builder__step" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.why }}</p>
            </li>
          {% endif %}
        {% endfor %}
      </ol>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Routine builder",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Your routine"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Morning and night, in order"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro",
      "default": "Thinnest texture first, sunscreen last. If a step isn't listed here, your skin doesn't need it."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "time",
          "label": "Time of day",
          "options": [
            {
              "value": "am",
              "label": "AM"
            },
            {
              "value": "pm",
              "label": "PM"
            }
          ],
          "default": "am"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product name",
          "default": "Cleanse"
        },
        {
          "type": "text",
          "id": "why",
          "label": "Why this step",
          "default": "A gentle wash that clears the night without stripping the barrier."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Routine builder",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "time": "am",
            "title": "Cleanse",
            "why": "A gentle wash that clears the night without stripping the barrier."
          }
        },
        {
          "type": "step",
          "settings": {
            "time": "am",
            "title": "Vitamin C",
            "why": "An antioxidant layer that supports brightness and evens tone over time."
          }
        },
        {
          "type": "step",
          "settings": {
            "time": "am",
            "title": "SPF",
            "why": "Broad-spectrum protection — the one step with the strongest evidence behind it."
          }
        },
        {
          "type": "step",
          "settings": {
            "time": "pm",
            "title": "Cleanse",
            "why": "Takes off sunscreen and the day so the next steps reach skin, not residue."
          }
        },
        {
          "type": "step",
          "settings": {
            "time": "pm",
            "title": "Retinal",
            "why": "Overnight renewal support, at a concentration most skin can build up to."
          }
        },
        {
          "type": "step",
          "settings": {
            "time": "pm",
            "title": "Barrier cream",
            "why": "Seals everything in and keeps water where it belongs — in your skin."
          }
        }
      ]
    }
  ]
}
{% endschema %}
