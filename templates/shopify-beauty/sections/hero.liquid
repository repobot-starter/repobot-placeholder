<section class="hero">
  {% if section.settings.eyebrow != blank %}
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <h1 class="hero__title">{{ section.settings.title }}</h1>
  <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
  <div class="hero__actions">
    {% if section.settings.cta_link != blank %}
      <a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
    {% endif %}
    {% if section.settings.secondary_cta_link != blank %}
      <a class="button button--ghost" href="{{ section.settings.secondary_cta_link }}">
        {{ section.settings.secondary_cta_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Clinically simple"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Three steps. Morning and night. That's the whole routine."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Short ingredient lists at working concentrations, in the order your skin actually uses them. Nothing to decode, nothing to skip."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Shop the routine"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary button link",
      "default": "/pages/ingredients"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button label",
      "default": "Learn the ingredients"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
