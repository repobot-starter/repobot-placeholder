<section class="bundle-callout">
  <h2 class="bundle-callout__title">{{ section.settings.title }}</h2>
  <p class="bundle-callout__body">{{ section.settings.body }}</p>
  {% if section.settings.cta_link != blank %}
    <a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
  {% endif %}
  {% if section.settings.small_print != blank %}
    <p class="bundle-callout__small-print">{{ section.settings.small_print }}</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Bundle callout",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The full routine, minus the guesswork."
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body",
      "default": "All six steps, sized to run out at the same time. One box, one reorder, no drawer of half-used bottles."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Get the routine set"
    },
    {
      "type": "text",
      "id": "small_print",
      "label": "Small print",
      "default": "Ships every 10 weeks by default. Change the pace or cancel anytime."
    }
  ],
  "presets": [
    {
      "name": "Bundle callout"
    }
  ]
}
{% endschema %}
