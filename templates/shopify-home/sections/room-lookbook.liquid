<section class="room-lookbook">
  {% if section.settings.eyebrow != blank %}
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <h2 class="section-heading">{{ section.settings.title }}</h2>
  <div class="room-lookbook__grid">
    {% for block in section.blocks %}
      <div class="room-lookbook__scene" {{ block.shopify_attributes }}>
        <div class="room-lookbook__media">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="900"
              height="{{ 900 | divided_by: block.settings.image.aspect_ratio | ceil }}"
            >
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          {% endif %}
        </div>
        <h3 class="room-lookbook__name">{{ block.settings.name }}</h3>
        <p class="room-lookbook__copy">{{ block.settings.copy }}</p>
        {% if block.settings.link_label != blank %}
          <a class="text-link" href="{{ block.settings.link | default: routes.all_products_collection_url }}">
            {{- block.settings.link_label -}}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Room lookbook",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Rooms, not showrooms"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Start with the room"
    }
  ],
  "blocks": [
    {
      "type": "room",
      "name": "Room scene",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Room image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Room name",
          "default": "The Living Room"
        },
        {
          "type": "text",
          "id": "copy",
          "label": "Description",
          "default": "Low sofas, a table that takes mugs without coasters, light you can read by."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop the room"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Room lookbook",
      "blocks": [
        {
          "type": "room",
          "settings": {
            "name": "The Living Room",
            "copy": "Low sofas, a table that takes mugs without coasters, light you can read by.",
            "link_label": "Shop the room"
          }
        },
        {
          "type": "room",
          "settings": {
            "name": "The Study",
            "copy": "A desk that holds still while you think, and shelving that earns its wall.",
            "link_label": "Shop the room"
          }
        },
        {
          "type": "room",
          "settings": {
            "name": "The Bedroom",
            "copy": "A bed frame that doesn't creak and linen that gets better after every wash.",
            "link_label": "Shop the room"
          }
        }
      ]
    }
  ]
}
{% endschema %}
