<section class="hero">
  <div class="hero__media" aria-hidden="true">
    {% if section.settings.image %}
      <img
        src="{{ section.settings.image | image_url: width: 1800 }}"
        alt="{{ section.settings.image.alt | escape }}"
        width="1800"
        height="{{ 1800 | divided_by: section.settings.image.aspect_ratio | ceil }}"
      >
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'hero__placeholder' }}
    {% endif %}
  </div>
  <div class="hero__panel">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h1 class="hero__title">{{ section.settings.title }}</h1>
    <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    <div class="hero__actions">
      {% if section.settings.cta_link != blank %}
        <a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {% endif %}
      {% if section.settings.secondary_cta_link != blank %}
        <a class="button button--ghost" href="{{ section.settings.secondary_cta_link }}">
          {{ section.settings.secondary_cta_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Room scene image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Made for rooms you live in"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Furniture that settles in"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Solid wood, honest joinery, and fabrics that wear their years well. Buy it once. Keep it long enough to argue about who inherits it."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Shop living"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary button link",
      "default": "/pages/materials"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button label",
      "default": "Browse materials"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
