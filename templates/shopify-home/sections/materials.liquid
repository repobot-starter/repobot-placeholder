<section class="materials">
  {% if section.settings.eyebrow != blank %}
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <h2 class="section-heading">{{ section.settings.title }}</h2>
  {% if section.settings.intro != blank %}
    <p class="materials__intro">{{ section.settings.intro }}</p>
  {% endif %}
  <div class="materials__grid">
    {% for block in section.blocks %}
      <div class="materials__card" {{ block.shopify_attributes }}>
        <span class="materials__swatch" style="background-color: {{ block.settings.swatch }};"></span>
        <h3 class="materials__name">{{ block.settings.name }}</h3>
        <p class="materials__sourcing">{{ block.settings.sourcing }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Materials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What it's made of"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Three materials, chosen slowly"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro",
      "default": "We'd rather master a short list than dabble in a long one. Everything in the catalog starts with these."
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        {
          "type": "color",
          "id": "swatch",
          "label": "Swatch color",
          "default": "#5d4433"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Walnut"
        },
        {
          "type": "text",
          "id": "sourcing",
          "label": "Sourcing line",
          "default": "American black walnut, air-dried for two years before it meets a blade."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Materials",
      "blocks": [
        {
          "type": "material",
          "settings": {
            "swatch": "#5d4433",
            "name": "Walnut",
            "sourcing": "American black walnut, air-dried for two years before it meets a blade."
          }
        },
        {
          "type": "material",
          "settings": {
            "swatch": "#e6e0d3",
            "name": "Bouclé",
            "sourcing": "A looped wool blend from a Belgian mill. It wears in, not out."
          }
        },
        {
          "type": "material",
          "settings": {
            "swatch": "#3a3d3b",
            "name": "Powder-coated steel",
            "sourcing": "Bent, welded, and coated an hour from the workshop. No plastic caps to lose."
          }
        }
      ]
    }
  ]
}
{% endschema %}
