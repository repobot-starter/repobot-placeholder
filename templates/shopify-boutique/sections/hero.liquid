<section class="hero">
  <div class="hero__content">
    {% if section.settings.eyebrow != blank %}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h1 class="hero__title">{{ section.settings.title }}</h1>
    <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    <div class="hero__actions">
      {% if section.settings.cta_label != blank %}
        <a class="button" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">
          {{- section.settings.cta_label -}}
        </a>
      {% endif %}
      {% if section.settings.secondary_cta_label != blank %}
        <a class="button button--ghost" href="{{ section.settings.secondary_cta_link | default: routes.root_url }}">
          {{- section.settings.secondary_cta_label -}}
        </a>
      {% endif %}
    </div>
  </div>
  <div class="hero__media">
    {{ 'collection-1' | placeholder_svg_tag }}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New season"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pieces made to keep, not to chase seasons"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Considered apparel and accessories, cut from natural fabrics and finished by hand."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Shop new arrivals"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button label",
      "default": "Explore the lookbook"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
