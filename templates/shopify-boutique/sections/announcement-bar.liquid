<div class="announcement-bar">
  {% if section.settings.link != blank %}
    <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {% else %}
    <span>{{ section.settings.text }}</span>
  {% endif %}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Complimentary shipping over $150 — every order, every day"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
