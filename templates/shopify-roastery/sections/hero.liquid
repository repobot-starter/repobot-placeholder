<section class="hero">
  {% if section.settings.eyebrow != blank %}
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <h1 class="hero__title">{{ section.settings.title }}</h1>
  <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
  <div class="hero__actions">
    {% if section.settings.cta_link != blank %}
      <a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
    {% endif %}
    {% if section.settings.secondary_cta_link != blank %}
      <a class="button button--ghost" href="{{ section.settings.secondary_cta_link }}">
        {{ section.settings.secondary_cta_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Small batch · Roasted weekly"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "This month's roast: Cloud Forest, Huila"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "A washed Colombian lot with dark-chocolate depth and a toasted-hazelnut finish. Roasted Tuesdays. At your door by the weekend."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Shop coffee"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary button link",
      "default": "/pages/how-we-roast"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button label",
      "default": "How we roast"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
