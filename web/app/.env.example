# All web/app environment variables. `.env.local` is generated from
# env.manifest.json by `npm run bootstrap:env` at the repo root; this file
# documents every VITE_ var across environments.

# GraphQL endpoint the web app talks to (all environments).
VITE_GRAPHQL_URL=http://127.0.0.1:5001/demo-repobot-base/us-central1/graphql__request__api

# "local" (dev JWT button on the login page) or "builtin" (email sign-in code + optional Google OAuth).
VITE_AUTH_MODE=local

# Display name shown on the login page. Falls back to "Welcome" when unset.
VITE_APP_NAME=

# "true" shows the "Continue with Google" button (requires the Google
# Sign-In integration to be connected for the environment). Hidden by default.
VITE_AUTH_GOOGLE_ENABLED=false

# Local mode only: signed dev-principal JWT generated by bootstrap:env.
VITE_LOCAL_AUTH_TOKEN=
